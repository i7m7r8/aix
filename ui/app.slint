// AIX VPN UI
import { Button, TextEdit, Text, HorizontalBox, VerticalBox } from "std-widgets.slint";

component App {
    property <string> status: "🔴 Disconnected";
    property <string> sni_input: "www.cloudflare.com";
    property <string> bridge_input: "webtunnel 185.220.101.1:443 sni-imitation=www.cloudflare.com fingerprint=...";
    property <string> log: "Edit Custom SNI or use presets below → then tap CONNECT";

    callback connect(string sni, string bridge);
    callback disconnect();

    VerticalBox {
        alignment: start;
        padding: 20px;

        // Header
        HorizontalBox {
            alignment: start;
            padding-bottom: 10px;
            Text {
                text: "AIX VPN";
                font-size: 32px;
                font-weight: 800;
            }
            Rectangle {
                width: 10px;
            }
            Text {
                text: status;
                font-size: 16px;
            }
        }

        // SNI Input
        Text {
            text: "🎯 Custom SNI";
            font-size: 18px;
            font-weight: 600;
        }
        TextEdit {
            text: sni_input;
            placeholder-text: "www.example.com";
            height: 48px;
            accept-tab: false;
            edit: true;
        }

        // Quick Presets
        Text {
            text: "⚡ Quick Presets";
            font-size: 16px;
            font-weight: 600;
        }
        HorizontalBox {
            spacing: 8px;
            Button {
                text: "Cloudflare SNI";
                clicked => {
                    sni_input = "www.cloudflare.com";
                    bridge_input = "webtunnel 185.220.101.1:443 sni-imitation=www.cloudflare.com fingerprint=...";
                    log = "✅ Loaded Cloudflare SNI preset";
                }
            }
            Button {
                text: "VK.ru SNI";
                clicked => {
                    sni_input = "vk.ru";
                    bridge_input = "webtunnel [2a0a:0:0:0::1]:443 sni-imitation=vk.ru fingerprint=...";
                    log = "✅ Loaded VK.ru SNI";
                }
            }
            Button {
                text: "Microsoft SNI";
                clicked => {
                    sni_input = "www.microsoft.com";
                    bridge_input = "webtunnel 185.220.101.2:443 sni-imitation=www.microsoft.com fingerprint=...";
                    log = "✅ Loaded Microsoft SNI";
                }
            }
            Button {
                text: "Yandex SNI";
                clicked => {
                    sni_input = "ya.ru";
                    bridge_input = "webtunnel 185.220.101.3:443 sni-imitation=ya.ru fingerprint=...";
                    log = "✅ Loaded Yandex SNI";
                }
            }
        }

        // Bridge Line
        Text {
            text: "🌉 Bridge Line";
            font-size: 16px;
            font-weight: 600;
        }
        TextEdit {
            text: bridge_input;
            placeholder-text: "bridge line...";
            height: 80px;
            accept-tab: false;
            wrap: word;
            edit: true;
        }

        // Log area
        TextEdit {
            text: log;
            read-only: true;
            height: 120px;
        }

        // Connect / Disconnect buttons
        HorizontalBox {
            spacing: 20px;
            Button {
                text: "CONNECT";
                primary: true;
                clicked => {
                    connect(sni_input, bridge_input);
                }
            }
            Button {
                text: "DISCONNECT";
                clicked => {
                    disconnect();
                }
            }
        }

        // Bottom navigation (simple)
        HorizontalBox {
            alignment: center;
            spacing: 20px;
            Text { text: "🏠 Home"; }
            Text { text: "🌉 Bridges"; }
            Text { text: "⚙️ Settings"; }
        }
    }
}
