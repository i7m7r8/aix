import { Button, CheckBox, ScrollView, VerticalBox, HorizontalBox, LineEdit, GroupBox } from "std-widgets.slint";

global Theme {
    out property <color> bg:           #0A0C10;
    out property <color> surface:      #1A1C22;
    out property <color> card:         #22252C;
    out property <color> accent:       #6C5CE7;
    out property <color> success:      #00D87E;
    out property <color> danger:       #FF6B6B;
    out property <color> warning:      #FFB347;
    out property <color> text:         #FFFFFF;
    out property <color> text-muted:   #8A8F99;
    out property <color> border:       #2F3542;
}

export component AppWindow inherits Window {
    title: "AIX VPN";
    preferred-width: 400px;
    preferred-height: 800px;
    background: Theme.bg;

    in-out property <string> sni_input: "www.cloudflare.com";
    in-out property <string> bridge_input: "";
    in-out property <bool>   kill_switch: true;
    in-out property <bool>   dns_over_tor: true;
    in-out property <bool>   auto_reconnect: true;
    in-out property <string> status_text: "🔴 Disconnected";
    in-out property <string> stats_text: "⏱ 00:00:00 | ↓0 B ↑0 B";
    in-out property <string> log_text: "";
    in-out property <string> error_text: "";
    in-out property <bool>   is_connected: false;
    in-out property <bool>   is_connecting: false;
    in-out property <int>    selected_tab: 0;
    in-out property <[string]> sni_presets;
    in-out property <[string]> bridge_presets;

    callback connect();
    callback disconnect();
    callback fetch_bridge();
    callback refresh_logs();
    callback clear_logs();
    callback sni_preset_selected(string);
    callback bridge_preset_selected(string);
    callback request_vpn_permission();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Header
        Rectangle {
            height: 56px;
            background: Theme.surface;
            
            HorizontalBox {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;
                
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Text { text: "⚡"; font-size: 24px; color: Theme.accent; }
                    Text { text: "AIX VPN"; font-size: 20px; font-weight: 700; color: Theme.text; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Rectangle { width: 8px; height: 8px; border-radius: 4px; background: is_connected ? Theme.success : (is_connecting ? Theme.warning : Theme.danger); }
                    Text { text: status_text; font-size: 11px; color: is_connected ? Theme.success : (is_connecting ? Theme.warning : Theme.text-muted); }
                }
            }
            
            // bottom border
            Rectangle {
                height: 1px;
                background: Theme.border;
                y: parent.height - 1px;
                width: 100%;
            }
        }

        // Stats bar
        Rectangle {
            height: 32px;
            background: Theme.card;
            HorizontalBox {
                alignment: center;
                spacing: 16px;
                Text { text: stats_text; font-size: 11px; color: Theme.text-muted; }
            }
        }

        // Error bar (if any)
        if error_text != "" : Rectangle {
            height: 32px;
            background: Theme.danger;
            HorizontalBox {
                alignment: center;
                Text { text: error_text; font-size: 10px; color: Theme.text; wrap: word-wrap; }
            }
        }

        // Main scrollable content
        ScrollView {
            vertical-stretch: 1;
            VerticalBox {
                padding: 16px;
                spacing: 20px;

                // Main Connect Card
                Rectangle {
                    background: Theme.card;
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: Theme.border;
                    VerticalBox {
                        padding: 20px;
                        spacing: 16px;
                        alignment: center;
                        Text { text: is_connected ? "🟢 CONNECTED" : (is_connecting ? "🟡 CONNECTING" : "⚫ DISCONNECTED"); font-size: 14px; font-weight: 700; color: is_connected ? Theme.success : (is_connecting ? Theme.warning : Theme.text-muted); }
                        
                        // Connect/Disconnect button without custom background
                        Button {
                            text: is_connected ? "DISCONNECT" : "CONNECT";
                            height: 56px;
                            clicked => { if is_connected { disconnect(); } else { connect(); } }
                        }
                        
                        HorizontalBox {
                            spacing: 12px; alignment: center;
                            Text { text: "🔒 SNI:"; font-size: 12px; color: Theme.text-muted; }
                            Text { text: sni_input; font-size: 12px; color: Theme.text; }
                        }
                        HorizontalBox {
                            spacing: 12px; alignment: center;
                            Text { text: "🌉 Bridge:"; font-size: 12px; color: Theme.text-muted; }
                            Text {
                                text: bridge_input == "" ? "None (direct)" : "Active";
                                font-size: 12px;
                                color: Theme.text;
                            }
                        }
                    }
                }

                // SNI Section
                Rectangle {
                    background: Theme.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.border;
                    VerticalBox {
                        padding: 16px;
                        spacing: 12px;
                        Text { text: "🎯 SNI HOSTNAME"; font-size: 12px; font-weight: 700; color: Theme.text-muted; letter-spacing: 1px; }
                        LineEdit { placeholder-text: "e.g. www.cloudflare.com"; text <=> sni_input; height: 44px; }
                        
                        // Presets label with spacing
                        Rectangle { height: 8px; }
                        Text { text: "Quick Presets"; font-size: 12px; font-weight: 600; color: Theme.text; }
                        GridLayout {
                            spacing: 8px;
                            for preset in sni_presets : Button {
                                text: preset;
                                height: 32px;
                                min-width: 80px;
                                clicked => { sni_preset_selected(preset); }
                            }
                        }
                        Text { text: "Used as TLS Server Name Indication to bypass DPI"; font-size: 10px; color: Theme.text-muted; wrap: word-wrap; }
                    }
                }

                // Bridge Section
                Rectangle {
                    background: Theme.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.border;
                    VerticalBox {
                        padding: 16px;
                        spacing: 12px;
                        Text { text: "🌉 BRIDGE LINE"; font-size: 12px; font-weight: 700; color: Theme.text-muted; letter-spacing: 1px; }
                        LineEdit {
                            text <=> bridge_input;
                            font-size: 11px;
                            height: 80px;
                        }
                        HorizontalBox {
                            spacing: 8px;
                            Button { text: "📋 Use Preset"; height: 32px; clicked => { /* handled by callback */ } }
                            Button { text: "🌐 Fetch from BridgeDB"; height: 32px; clicked => { fetch_bridge(); } }
                        }
                        Text { text: "WebTunnel, obfs4, meek-azure, or direct"; font-size: 10px; color: Theme.text-muted; }
                    }
                }

                // Security Options
                Rectangle {
                    background: Theme.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.border;
                    VerticalBox {
                        padding: 16px;
                        spacing: 12px;
                        Text { text: "🛡️ SECURITY"; font-size: 12px; font-weight: 700; color: Theme.text-muted; letter-spacing: 1px; }
                        HorizontalBox { alignment: space-between; VerticalBox { Text { text: "Kill Switch"; font-size: 14px; color: Theme.text; } Text { text: "Block all traffic if VPN drops"; font-size: 10px; color: Theme.text-muted; } } CheckBox { checked <=> kill_switch; } }
                        HorizontalBox { alignment: space-between; VerticalBox { Text { text: "DNS over Tor"; font-size: 14px; color: Theme.text; } Text { text: "Route DNS through Tor network"; font-size: 10px; color: Theme.text-muted; } } CheckBox { checked <=> dns_over_tor; } }
                        HorizontalBox { alignment: space-between; VerticalBox { Text { text: "Auto-reconnect"; font-size: 14px; color: Theme.text; } Text { text: "Reconnect automatically on drop"; font-size: 10px; color: Theme.text-muted; } } CheckBox { checked <=> auto_reconnect; } }
                    }
                }

                // Log Section
                Rectangle {
                    background: Theme.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.border;
                    VerticalBox {
                        padding: 16px;
                        spacing: 12px;
                        HorizontalBox { alignment: space-between; Text { text: "📋 CONNECTION LOG"; font-size: 12px; font-weight: 700; color: Theme.text-muted; letter-spacing: 1px; } HorizontalBox { spacing: 8px; Button { text: "🔄"; height: 32px; clicked => { refresh_logs(); } } Button { text: "🗑️"; height: 32px; clicked => { clear_logs(); } } } }
                        Rectangle {
                            background: Theme.bg;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: Theme.border;
                            height: 120px;
                            ScrollView {
                                // Use a VerticalBox inside to apply padding correctly
                                VerticalBox {
                                    padding: 8px;
                                    Text {
                                        text: log_text == "" ? "Ready. Click CONNECT to start.\n" : log_text;
                                        font-size: 10px;
                                        color: Theme.success;
                                        wrap: word-wrap;
                                        font-family: "monospace";
                                    }
                                }
                            }
                        }
                    }
                }

                // About Section
                Rectangle {
                    background: Theme.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.border;
                    VerticalBox {
                        padding: 16px;
                        spacing: 8px;
                        alignment: center;
                        Text { text: "AIX VPN v0.1.0"; font-size: 12px; color: Theme.text-muted; }
                        Text { text: "SNI + Tor Routing Engine"; font-size: 10px; color: Theme.text-muted; }
                        Text { text: "github.com/i7m7r8/aix"; font-size: 10px; color: Theme.accent; }
                    }
                }
            }
        }
    }
}
