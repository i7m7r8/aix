import { Button, CheckBox, ScrollView, TabWidget, VerticalBox, HorizontalBox, LineEdit, GroupBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "AIX VPN";
    preferred-width: 400px;
    preferred-height: 750px;
    background: #0a0a0f;

    // Properties
    in-out property <string> sni_input;
    in-out property <string> bridge_input;
    in-out property <bool>   kill_switch;
    in-out property <bool>   dns_over_tor;
    in-out property <bool>   auto_reconnect;
    in-out property <string> status_text: "🔴 Disconnected";
    in-out property <string> stats_text: "⏱ 00:00:00 | ↓0 B ↑0 B";
    in-out property <string> log_text;
    in-out property <bool>   is_connected: false;
    in-out property <int>    selected_tab: 0;
    in-out property <[string]> sni_presets;
    in-out property <[string]> bridge_presets;

    // Callbacks
    callback connect();
    callback disconnect();
    callback new_circuit();
    callback fetch_bridge();
    callback refresh_logs();
    callback clear_logs();
    callback sni_preset_selected(string);
    callback bridge_preset_selected(string);

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Header
        Rectangle {
            height: 64px;
            background: #12121a;
            HorizontalBox {
                padding: 16px;
                spacing: 12px;
                Text {
                    text: "⚡ AIX VPN";
                    font-size: 22px;
                    font-weight: 700;
                    color: #e0e0ff;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 120px;
                    height: 32px;
                    border-radius: 8px;
                    background: is_connected ? #1a3a1a : #3a1a1a;
                    border-width: 1px;
                    border-color: is_connected ? #44ff44 : #ff4444;
                    Text {
                        text: status_text;
                        font-size: 11px;
                        color: is_connected ? #44ff44 : #ff6666;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }

        // Stats bar
        Rectangle {
            height: 28px;
            background: #0d0d14;
            Text {
                text: stats_text;
                font-size: 11px;
                color: #8888aa;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Tabs
        TabWidget {
            vertical-stretch: 1;
            current-index: selected_tab;

            // ── Tab 1: Connect ──────────────────────────────────────────
            Tab {
                title: "🔒 Connect";
                ScrollView {
                    VerticalBox {
                        padding: 14px;
                        spacing: 10px;

                        GroupBox {
                            title: "SNI Hostname (TLS bypass)";
                            VerticalBox {
                                spacing: 6px;
                                HorizontalBox {
                                    spacing: 6px;
                                    for preset in sni_presets : Button {
                                        text: preset;
                                        clicked => { root.sni_preset_selected(preset); }
                                    }
                                }
                                LineEdit {
                                    placeholder-text: "Custom SNI e.g. www.cloudflare.com";
                                    text <=> sni_input;
                                }
                            }
                        }

                        GroupBox {
                            title: "Bridge";
                            VerticalBox {
                                spacing: 6px;
                                HorizontalBox {
                                    spacing: 6px;
                                    for preset in bridge_presets : Button {
                                        text: preset;
                                        clicked => { root.bridge_preset_selected(preset); }
                                    }
                                }
                                LineEdit {
                                    placeholder-text: "Paste bridge line or leave empty";
                                    text <=> bridge_input;
                                }
                                Button {
                                    text: "🌐 Fetch bridge from BridgeDB";
                                    clicked => { root.fetch_bridge(); }
                                }
                            }
                        }

                        GroupBox {
                            title: "Options";
                            VerticalBox {
                                spacing: 4px;
                                CheckBox { text: "🛡️  Kill Switch"; checked <=> kill_switch; }
                                CheckBox { text: "🔒 DNS over Tor"; checked <=> dns_over_tor; }
                                CheckBox { text: "🔄 Auto-reconnect"; checked <=> auto_reconnect; }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }

                        if !is_connected : Button {
                            text: "⚡ CONNECT";
                            primary: true;
                            height: 48px;
                            clicked => { root.connect(); }
                        }
                        if is_connected : VerticalBox {
                            spacing: 8px;
                            Button {
                                text: "🔴 DISCONNECT";
                                height: 48px;
                                clicked => { root.disconnect(); }
                            }
                            Button {
                                text: "♻️  New Circuit";
                                clicked => { root.new_circuit(); }
                            }
                        }
                    }
                }
            }

            // ── Tab 2: Logs ─────────────────────────────────────────────
            Tab {
                title: "📋 Logs";
                VerticalBox {
                    padding: 10px;
                    spacing: 8px;
                    HorizontalBox {
                        spacing: 8px;
                        Button { text: "🔄 Refresh"; clicked => { root.refresh_logs(); } }
                        Button { text: "🗑️  Clear";   clicked => { root.clear_logs();   } }
                    }
                    ScrollView {
                        vertical-stretch: 1;
                        Rectangle {
                            background: #0d0d14;
                            border-radius: 6px;
                            // Remove padding on Text, add margin on the rectangle instead
                            Text {
                                text: log_text;
                                font-size: 10px;
                                color: #99ffcc;
                                wrap: word-wrap;
                                font-family: "monospace";
                                margin: 8px;
                            }
                        }
                    }
                }
            }

            // ── Tab 3: About ────────────────────────────────────────────
            Tab {
                title: "ℹ️  About";
                ScrollView {
                    VerticalBox {
                        padding: 20px;
                        spacing: 12px;
                        alignment: center;
                        Text { text: "⚡ AIX VPN"; font-size: 28px; font-weight: 700; color: #e0e0ff; horizontal-alignment: center; }
                        Text { text: "SNI + Tor Privacy VPN"; font-size: 14px; color: #8888cc; horizontal-alignment: center; }
                        Text { text: "v0.1.0"; font-size: 12px; color: #555577; horizontal-alignment: center; }
                        Rectangle { height: 1px; background: #222233; }
                        Text {
                            text: "How it works:\n\n1. SNI hostname set → used as TLS handshake server name\n2. Bridge transport opens TLS connection with that SNI\n3. ISP sees traffic to e.g. cloudflare.com\n4. Tor bootstraps inside the encrypted tunnel\n5. All device traffic routes through Tor onion layers";
                            font-size: 12px;
                            color: #9999bb;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
